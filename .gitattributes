# Normalizar line endings cross-platform Mac/Windows.
# Git normaliza a LF al hacer commit; en checkout respeta el OS (LF en Mac/Linux, CRLF en Windows).
* text=auto eol=lf

# Binarios — no normalizar.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.svg binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary

# Lockfile de Bun — binario.
bun.lockb binary

# Archivos que SIEMPRE deben ser LF independientemente del OS.
*.sh text eol=lf
*.bash text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.sql text eol=lf
