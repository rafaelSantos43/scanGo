# EditorConfig — convenciones de editor cross-platform.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Markdown puede tener trailing whitespace con significado (line break).
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
